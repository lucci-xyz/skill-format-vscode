{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "`", "close": "`" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["`", "`"],
    ["\"", "\""],
    ["'", "'"],
    ["*", "*"],
    ["_", "_"]
  ],
  "folding": {
    "markers": {
      "start": "^---\\s*$",
      "end": "^---\\s*$"
    }
  }
}
